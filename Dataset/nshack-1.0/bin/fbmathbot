#!/usr/bin/python
from nshack import *

T = TEXT()
C = COLOR()

print(C.G)
print(T.textart('FB Math-BoT'))
print("""
           {} BY Nasir Ali    
      {}  Powered By NHack-Library
          {}${}pip install nshack
                 
  """.format(C.W,C.Y,C.G,C.W))


a = FB()
key = input(C.greentick()+' Enter Key : '+C.R)
a.setkey(key)

print(C.Y)
b = BOT(a)
b.InboxMathBOT()
